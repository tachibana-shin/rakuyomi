# OAuth tracking bridge - MyAnimeList (PKCE, no secret)
MAL_CLIENT_ID=

# OAuth tracking bridge - Shikimori
SHIKIMORI_CLIENT_ID=
SHIKIMORI_CLIENT_SECRET=

# OAuth tracking bridge - Bangumi
BANGUMI_CLIENT_ID=
BANGUMI_CLIENT_SECRET=

# OAuth tracking bridge - MangaBaka (PKCE S256, no secret)
MANGABAKA_CLIENT_ID=
