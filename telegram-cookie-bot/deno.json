{
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "fmt": {
    "semiColons": false
  },
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env --env-file main.ts",
    "test": "deno test --allow-env --allow-net"
  },
  "imports": {
    "@libsql/client": "npm:@libsql/client@^0.14.0",

    "grammy": "npm:grammy@1.34.1",
    "hono": "npm:hono@^4.12.28",
    "@hono/zod-openapi": "npm:@hono/zod-openapi@^1.4.0",
    "@hono/zod-validator": "npm:@hono/zod-validator@^0.4.0",
    "zod": "npm:zod@^3.24.4"
  }
}
