{
  "db_name": "SQLite",
  "query": "\n            SELECT \n                md.source_id AS \"source_id!\",\n                md.id AS \"id!\", \n                md.title,\n                md.author,\n                md.artist,\n                md.description,\n                md.tags,\n                md.cover_url,\n                md.url,\n                md.status AS \"status!\",\n                md.nsfw AS \"nsfw!\",\n                md.viewer AS \"viewer!\",\n                md.last_updated,\n                md.last_opened,\n                COALESCE(MAX(cs.last_read), 0) AS \"last_read: i64\",\n                md.date_added,\n                COALESCE(AVG(cs.read), 0) AS \"per_read: f64\"\n            FROM manga_details md\n            LEFT JOIN chapter_state cs\n                ON cs.source_id = md.source_id\n                AND cs.manga_id = md.id\n            WHERE md.source_id = ?1 AND md.id = ?2\n            GROUP BY md.source_id, md.id\n            ",
