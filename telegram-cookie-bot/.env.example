BOT_TOKEN=your_telegram_bot_token
PUBLIC_URL=https://your-server-url.example.com
TURSO_DB_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token
API_TOKEN=your_api_token_for_rust_backend
USE_WEBHOOK=true

# OAuth tracking bridge - AniList
ANILIST_CLIENT_ID=
